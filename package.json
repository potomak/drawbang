{
  "name": "drawbang",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Pixel art editor + static gallery with proof-of-work anonymous submissions",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "node --test --import tsx 'test/**/*.test.ts'",
    "builder": "tsx builder/build.ts",
    "ingest:dev": "tsx ingest/dev-server.ts",
    "worker:dev": "wrangler dev --config infra/wrangler.toml --local",
    "worker:deploy": "wrangler deploy --config infra/wrangler.toml",
    "pages:deploy": "npm run build && wrangler pages deploy dist --project-name=drawbang"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@types/mustache": "^4.2.5",
    "gifenc": "^1.0.3",
    "mustache": "^4.2.0",
    "omggif": "^1.0.10"
  }
}
