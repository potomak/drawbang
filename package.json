{
  "name": "drawbang",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Pixel art editor + static gallery with proof-of-work anonymous submissions",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "node --test --import tsx 'test/**/*.test.ts'",
    "builder": "tsx builder/build.ts",
    "ingest:dev": "tsx ingest/dev-server.ts",
    "lambda:build": "node infra/aws/build-lambda.mjs",
    "lambda:deploy": "npm run lambda:build && (cd infra/aws && sam deploy)"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^22.5.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "gifenc": "^1.0.3",
    "omggif": "^1.0.10"
  }
}
