# Editor → ingest Lambda URL. API Gateway invoke URL in prod.
VITE_INGEST_URL=

# URL where last-publish.json is served (S3 bucket in prod).
VITE_STATE_URL=

# S3 URL prefix for drawing gifs in prod, e.g.
# https://drawbang-assets.s3.us-east-1.amazonaws.com/public/drawings
VITE_DRAWING_BASE_URL=

# Vite public path; /drawbang/ on GitHub Pages, / for local dev.
VITE_BASE=
