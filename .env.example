# Editor → ingest worker. Defaults to same-origin /ingest for the dev server.
# In production set this to the Worker route, e.g. https://api.drawbang.example/ingest
VITE_INGEST_URL=

# Editor → last-publish state file. Same-origin path in dev; Worker URL in prod.
VITE_STATE_URL=

# Origin where published gifs are served (R2 custom domain in prod).
# Leave empty for same-origin (dev). Example: https://cdn.drawbang.example
VITE_DRAWING_BASE_URL=
